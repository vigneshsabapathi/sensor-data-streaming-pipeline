# Confluent Kafka
API_KEY=your-kafka-api-key
API_SECRET_KEY=your-kafka-api-secret
BOOTSTRAP_SERVER=your-bootstrap-server:9092
SECURITY_PROTOCOL=SASL_SSL
SASL_MECHANISM=PLAIN

# Confluent Schema Registry
ENDPOINT_SCHEMA_URL=https://your-schema-registry-url
SCHEMA_REGISTRY_API_KEY=your-schema-registry-key
SCHEMA_REGISTRY_API_SECRET=your-schema-registry-secret

# MongoDB
MONGO_DB_URL=mongodb+srv://user:pass@cluster.mongodb.net
MONGO_DB_NAME=ineuron

# Consumer
CONSUMER_GROUP_ID=sensor-pipeline-group
CONSUMER_BATCH_SIZE=5000
AUTO_OFFSET_RESET=earliest
